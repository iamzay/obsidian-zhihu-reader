{
  "name": "zhihu-reader",
  "version": "0.1.5",
  "description": "An Obsidian plugin for reading Zhihu questions and answers.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit && node esbuild.config.mjs production",
    "lint": "eslint src tests vitest.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:release": "node --check scripts/release.mjs",
    "check": "npm run lint && npm run test && npm run check:release && npm run build",
    "release": "node scripts/release.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "turndown": "^7.2.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@types/node": "^22.15.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/turndown": "^5.0.5",
    "esbuild": "^0.25.0",
    "eslint": "^9.30.0",
    "eslint-import-resolver-typescript": "^4.4.0",
    "eslint-plugin-import-x": "^4.16.0",
    "globals": "^16.2.0",
    "obsidian": "1.8.7",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.0"
  }
}
